# Noxivo SaaS - Local Development & Production Environment Template
# Copy this to .env and fill in the values

# --- SHARED ---
NODE_ENV=production
PROJECT_NAME=noxivo-saas

# --- DATABASE AUTH ---
# Mandatory for Docker Compose and Dokploy
MONGO_USER=nexus
MONGO_PASSWORD=your_secure_mongo_password
REDIS_PASSWORD=your_secure_redis_password

# --- DATABASE URIs (Computed) ---
# Used if you are NOT using the individual variables above
MONGODB_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongodb:27017/noxivo?authSource=admin
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# --- WORKFLOW ENGINE ---
PORT=4000
ENGINE_API_KEY=your_engine_api_key
WORKFLOW_ENGINE_INTERNAL_PSK=your_very_secret_psk_here

# --- Messaging Provider (WhatsApp HTTP API) ---
# Remote-only Messaging Provider endpoints (local Messaging Provider is not supported)
MESSAGING_PROVIDER_BASE_URL=https://your-remote-messaging-provider-instance.com
MESSAGING_PROVIDER_PROXY_BASE_URL=https://your-remote-messaging-provider-instance.com
MESSAGING_PROVIDER_API_KEY=your_messaging_provider_auth_token
MESSAGING_PROVIDER_WEBHOOK_SECRET=your_webhook_signature_secret

# --- DASHBOARD ---
# NEXT_PUBLIC_ vars are exposed to the browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_ENGINE_BASE_URL=http://localhost:4000

# NextAuth / Custom Session
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
