# ────────────────────────────────────────────────────────────────────────────
# .env.engine.example
# Copy to .env.engine, fill in real values, then:
#   docker-compose -f docker-compose.engine.yml --env-file .env.engine up -d
# ────────────────────────────────────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_USER=nexus
MONGO_PASSWORD=change-me-strong-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password

# ── Internal Messaging Adapter API key (never expose this externally) ─────────
ADAPTER_API_KEY=change-me-adapter-secret
ADAPTER_WEBHOOK_SECRET=change-me-webhook-secret

# ── Messaging Provider Connection (External API) ─────────────────────────────
MESSAGING_PROVIDER_BASE_URL=https://workflow-engine.khelifi-salmen.com
MESSAGING_PROVIDER_PROXY_BASE_URL=https://workflow-engine.khelifi-salmen.com
MESSAGING_PROVIDER_API_KEY=messagingSecretKey2025!
MESSAGING_PROVIDER_WEBHOOK_SECRET=your_Messaging_webhook_secret_here

# ── Engine Public API key (external clients pass this as: X-API-Key: <key>) ──
ENGINE_API_KEY=change-me-engine-public-key

# ── Internal PSK for dashboard → engine trusted calls ────────────────────────
WORKFLOW_ENGINE_INTERNAL_PSK=change-me-internal-psk

# ── Engine Port (host:container — container always listens on 3200) ───────────
ENGINE_PORT=3200
